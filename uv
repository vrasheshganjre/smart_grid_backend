#!/usr/bin/env python3
"""
uv — lightweight development helper for this repository.

Usage:
  ./uv venv            # create virtualenv (python3.13 by default)
  ./uv sync            # create venv (if missing) and install deps
  ./uv run             # run the API via uvicorn from the venv
  ./uv shell           # open an interactive shell with venv on PATH
  ./uv status          # show venv / python / pip status

This script is intentionally small and has no external dependencies. You can run it
directly with `python uv <cmd>` or make it executable: `chmod +x uv`.
"""
import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

VENV_DIR = Path('.venv')


def bin_dir():
    b = VENV_DIR / 'bin'
    if b.exists():
        return b
    b = VENV_DIR / 'Scripts'
    return b


def venv_python(python_exec='python3.13'):
    p = bin_dir() / 'python'
    if p.exists():
        return str(p)
    found = shutil.which(python_exec)
    if found:
        return found
    return sys.executable


def run_cmd(cmd, env=None, check=True):
    print("+ " + " ".join(cmd))
    return subprocess.run(cmd, check=check, env=env)


def create_venv(python_exec='python3.13'):
    if VENV_DIR.exists():
        print(f"Virtual env already exists at {VENV_DIR}")
        return True
    python_found = shutil.which(python_exec) or sys.executable
    print(f"Creating virtualenv {VENV_DIR} using {python_found} ...")
    run_cmd([python_found, '-m', 'venv', str(VENV_DIR)])
    print("Created virtualenv:", VENV_DIR)
    return True


def sync_deps(python_exec='python3.13', install_dev=True):
    create_venv(python_exec)
    pip = str(bin_dir() / 'pip')
    run_cmd([pip, 'install', '--upgrade', 'pip'])
    req = Path('requirements.txt')
    if req.exists():
        run_cmd([pip, 'install', '-r', str(req)])
    else:
        print('No requirements.txt found')
    req_dev = Path('requirements-dev.txt')
    if install_dev and req_dev.exists():
        run_cmd([pip, 'install', '-r', str(req_dev)])
    elif install_dev:
        print('No requirements-dev.txt found')
    print('Dependencies installed.')


def run_server(host='127.0.0.1', port=8000, reload=True):
    create_venv()
    python_exec = venv_python()
    cmd = [python_exec, '-m', 'uvicorn', 'app.main:app', '--host', host, '--port', str(port)]
    if reload:
        cmd += ['--reload']
    run_cmd(cmd)


def open_shell():
    create_venv()
    env = os.environ.copy()
    p = str(bin_dir())
    env['PATH'] = p + os.pathsep + env.get('PATH', '')
    shell = env.get('SHELL', '/bin/bash')
    print(f"Launching shell with {VENV_DIR}/bin on PATH")
    os.execvpe(shell, [shell], env)


def status():
    print('Venv:', VENV_DIR, 'exists' if VENV_DIR.exists() else 'missing')
    if VENV_DIR.exists():
        python_exec = venv_python()
        run_cmd([python_exec, '--version'], check=False)
        pip = str(bin_dir() / 'pip')
        run_cmd([pip, 'list'], check=False)


def main():
    parser = argparse.ArgumentParser(prog='uv', description='Lightweight dev helper')
    sub = parser.add_subparsers(dest='cmd')
    p_venv = sub.add_parser('venv', help='Create virtual environment')
    p_venv.add_argument('--python', default='python3.13')
    p_sync = sub.add_parser('sync', help='Create venv (if needed) and install dependencies')
    p_sync.add_argument('--python', default='python3.13')
    p_sync.add_argument('--no-dev', action='store_true')
    p_run = sub.add_parser('run', help='Run the FastAPI server (uvicorn)')
    p_run.add_argument('--host', default='127.0.0.1')
    p_run.add_argument('--port', default=8000, type=int)
    p_run.add_argument('--no-reload', action='store_true')
    sub.add_parser('shell', help='Open shell with venv activated')
    sub.add_parser('status', help='Show venv status')
    args = parser.parse_args()
    if not args.cmd:
        parser.print_help()
        sys.exit(1)
    if args.cmd == 'venv':
        create_venv(args.python)
    elif args.cmd == 'sync':
        sync_deps(args.python, not args.no_dev)
    elif args.cmd == 'run':
        run_server(args.host, args.port, not args.no_reload)
    elif args.cmd == 'shell':
        open_shell()
    elif args.cmd == 'status':
        status()


if __name__ == '__main__':
    main()
